[Desktop Entry]
Version=1.0
Type=Application
Name=Guardar Sesión
Comment=Guarda las ventanas abiertas y sus escritorios virtuales
Icon=document-save
Exec=bash -c 'python3 ~/.local/bin/session-save.py; echo; echo "Presiona Enter para cerrar"; read'
Terminal=true
Categories=Utility;
StartupNotify=false
